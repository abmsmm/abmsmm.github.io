<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Private Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; background: #121212; color: white; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .box { background: #1e1e1e; padding: 30px; border-radius: 10px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.5); width: 85%; max-width: 400px; }
        input { padding: 12px; width: 90%; margin: 15px 0; border: none; border-radius: 5px; background: #2a2a2a; color: white; font-size: 16px; text-align: center; }
        button { padding: 12px 25px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 16px; font-weight: bold; width: 95%; }
        button:hover { background: #0056b3; }
        .hidden { display: none !important; }
        .panel-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; margin-top: 20px; }
        .card { background: #2a2a2a; padding: 20px; border-radius: 8px; text-decoration: none; color: #00adb5; font-weight: bold; font-size: 16px; border: 1px solid #333; }
        .card:active { background: #333; }
    </style>
</head>
<body>

    <!-- PASSWORD GATE -->
    <div id="login-box" class="box">
        <h2>Private Access</h2>
        <p style="color: #aaa; font-size: 14px;">Enter your secret password below</p>
        <input type="password" id="pass" placeholder="Password...">
        <br>
        <button onclick="checkPass()">Unlock Panel</button>
    </div>

    <!-- YOUR PRIVATE PANEL -->
    <div id="panel-box" class="box hidden">
        <h2>My Control Panel</h2>
        <p style="color: #aaa; font-size: 14px;">Welcome back, Admin.</p>
        <div class="panel-grid">
            <a href="https://google.com" target="_blank" class="card">Google</a>
            <a href="https://github.com" target="_blank" class="card">GitHub</a>
            <!-- You can add more shortcut links here later -->
        </div>
    </div>

    <script>
        function checkPass() {
            // Your default password is '1234'. Change it inside the quotes below if you want!
            if (document.getElementById('pass').value === '1234') {
                document.getElementById('login-box').classList.add('hidden');
                document.getElementById('panel-box').classList.remove('hidden');
            } else {
                alert('Access Denied: Incorrect Password');
            }
        }
    </script>
</body>
</html>
